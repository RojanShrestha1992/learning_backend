<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
</head>
<body class="bg-zinc-900"> 
    <div class="main w-full min-h-screen bg-zinc-900 mx-auto max-w-7xl mt-10">
        <a href="/" class="text-blue-500 hover:text-blue-400">Go back</a>
     <form action="/edit" method="post">
                <input value="<%= filename %>" name="prevTitle" class="disabled block px-5 w-80  py-2 rounded-md bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" name="" id="" placeholder="prev title">
                <input  name="newTitle" class="block px-5 w-80  py-2 mt-2 rounded-md bg-zinc-800 text-white placeholder:text-zinc-500 border border-zinc-600 focus:outline-none focus:ring-2 focus:ring-blue-500" type="text" name="" id="" placeholder="new title">

                <input class="block mt-2 px-5 py-2 bg-blue-600 text-white hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-blue-500" type="submit" value="update name">
            </form>
            

           
        </div>
    </div>
</body>
</html>